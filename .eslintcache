[allComments, setAllComments] = useState([]);\n\n\n  const getUser = (userData) => {\n    setUser (user=>{return user = userData})\n  }\n\n  const getAllPostsForHomePage = (postData) => {\n    setAllPosts(allPosts=>{return allPosts = postData})\n  }\n\n  const getDetailedPost = (detailedPostData) => {\n    setDetailedPost(allDetailedPostData =>{return allDetailedPostData = detailedPostData}) \n  }\n\n  const getAllComments = (commentsData) => {\n    setAllComments(allCommentsData => {return allCommentsData = commentsData})\n  } \n\n\n  return (\n    <UserProvider value = {{\n      user,\n      allPosts,\n      detailedPost,\n      allComments,\n\n      getUser,\n      getAllPostsForHomePage,\n      getDetailedPost,\n      getAllComments\n    }}>\n    <Router>\n      <Route exact activeClassName path=\"/\" component={Login} />\n      <Route exact activeClassName path=\"/signup\" component={Signup} />\n      <NavbarTop/>\n      <Switch>\n      <Route exact activeClassName path=\"/home\" component={Home} />\n      </Switch>\n      <Route exact activeClassName path=\"/indepthpost\" component={InDepthPost} />\n      <Route exact activeClassName path=\"/myaccount\" component={MyAccount} />\n    </Router>\n    </UserProvider>\n\n\n\n\n\n  );\n}\n\nexport default App;\n",["56","57"],"/Users/logan/Desktop/peak-react/peak-fe/src/screens/Home.js",["58","59"],"/Users/logan/Desktop/peak-react/peak-fe/src/screens/Signup.js",[],["60","61"],"/Users/logan/Desktop/peak-react/peak-fe/src/components/navbar/index.js",["62","63"],"/Users/logan/Desktop/peak-react/peak-fe/src/utils/API.js",[],"/Users/logan/Desktop/peak-react/peak-fe/src/screens/MyAccount.js",["64","65","66","67"],"/Users/logan/Desktop/peak-react/peak-fe/src/reportWebVitals.js",[],["68","69"],"/Users/logan/Desktop/peak-react/peak-fe/src/screens/Login.js",[],"/Users/logan/Desktop/peak-react/peak-fe/src/screens/InDepthPost.js",["70","71","72","73","74","75","76","77"],"import React, { useContext, useEffect, useState } from 'react';\nimport '../stylesheets/inDepthPostOutput.css';\nimport API from '../utils/API';\nimport UserContext from '../utils/Context';\n\nexport default function InDepthPost() {\n\n    const { detailedPost } = useContext(UserContext);\n    console.log(detailedPost , \"i am a detailed post \")\n\n    const [commentsToMap, setCommentsToMap] = useState(detailedPost.comments);\n    const [postToMap, setPostToMap] = useState(detailedPost.results)\n    const [userNamesForComments, setUsernameForComments] = useState([]);\n    const [loading, isLoading] = useState(true);\n    const [idkRandom , setIdkRandom] = useState(userNamesForComments);\n    const [visibilityCond , setVisibility] = useState(\"visible\");\n    var userIdForApi = [];\n\n    setTimeout(() => {\n        if(userNamesForComments.length === 0 && commentsToMap === null){\n            setIdkRandom([\"\" , \"\" , \"\"]);\n            setCommentsToMap([\"\" , \"\" , \"\"]);\n            setVisibility(\"none\")\n        }else{\n            console.log(\"it worked\")\n        }\n    }, 2 * 200)\n\n    useEffect(async () => (\n        someRandomFunc()\n    ), [])\n\n    const someRandomFunc = () => {\n        commentsToMap.map(async (index) => {\n            userIdForApi.push(index.user_id)\n            setTimeout(async () => {\n                await API.getUsernamesForComments(userIdForApi)\n                    .then((res) => setUsernameForComments(res.data));\n                if (userNamesForComments.length !== 0) {\n                    return\n                } else {\n                    console.log(\"i give up\")\n                }\n            }, 1 * 10)\n        })\n    }\n\n    useEffect(() => {\n        if (postToMap.length !== 0) {\n            isLoading(false);\n        }\n    }, [isLoading])\n\n    if (loading === true) {\n        return (\n            <div>\n                <h1>Loading</h1>\n            </div>\n        )\n    } else if (loading === false) {\n        console.log(userNamesForComments, \"user name for comments to maaap\")\n        return (\n            <div className=\"inDepthPostPage conatiner-fluid \">\n                {(postToMap.map((index) => (\n                    <>\n                        <div id=\"blogImgCont\" className=\"blogImgCont\" >\n                            <div className=\"blogImg\" id=\"blogImg\" style={{ backgroundImage: `url(${index.blog_img})` }}></div>\n                        </div>\n                        <div className=\"publishingInfo\" id=\"publishingInfo\">\n                            <h1 id=\"blogTitle\">{index.post_title}</h1>\n                            <i className=\"far fa-heart\"></i>\n                            {/* <h1 id=\"blogLikes\">{index.blog_likes}</h1> */}\n                            {/* <h1 id=\"blogPublishDate\">{index.publish_date}</h1> */}\n                        </div>\n                        <h2 className=\"blogBody\" id=\"blogBody\">{index.post_body}</h2>\n                    </>\n                )))}\n                <div className=\"commentsCont\" style={{visibility : `${visibilityCond}`}}>\n                    <h1 className=\"commentsTitle\">Comments</h1>\n                    {(commentsToMap.map((index, myKey) => (\n                        ((console.log(index, \"indeeeexxx\"))),\n                        <>\n                            {(userNamesForComments.map((indexTwo) => (\n                                ((console.log(indexTwo, \"index twoooooo\"))),\n                                <div className=\"actualCommentsCont\">\n                                    <div className=\"commentAuthDiv\">\n                                        <img className=\"commentAuthPic\"></img>\n                                        <h4>{indexTwo}</h4>\n                                    </div>\n                                    <p>{index.comment_body}</p>\n                                </div>\n                            )))}\n                        </>\n                    )))}\n                </div>\n            </div>\n        )\n    }\n}","/Users/logan/Desktop/peak-react/peak-fe/src/utils/Context.js",[],"/Users/logan/Desktop/peak-react/peak-fe/src/index.js",[],"/Users/logan/Desktop/peak-react/peak-fe/src/components/heartCont/index.js",["78","79","80","81","82","83"],{"ruleId":"84","severity":1,"message":"85","line":1,"column":8,"nodeType":"86","messageId":"87","endLine":1,"endColumn":12},{"ruleId":"88","replacedBy":"89"},{"ruleId":"90","replacedBy":"91"},{"ruleId":"92","severity":1,"message":"93","line":21,"column":15,"nodeType":"94","endLine":24,"endColumn":10},{"ruleId":"95","severity":1,"message":"96","line":89,"column":41,"nodeType":"97","endLine":89,"endColumn":68},{"ruleId":"88","replacedBy":"98"},{"ruleId":"90","replacedBy":"99"},{"ruleId":"84","severity":1,"message":"100","line":1,"column":17,"nodeType":"86","messageId":"87","endLine":1,"endColumn":27},{"ruleId":"84","severity":1,"message":"101","line":1,"column":29,"nodeType":"86","messageId":"87","endLine":1,"endColumn":38},{"ruleId":"102","severity":1,"message":"103","line":15,"column":25,"nodeType":"104","messageId":"105","endLine":15,"endColumn":26},{"ruleId":"92","severity":1,"message":"106","line":17,"column":8,"nodeType":"107","endLine":17,"endColumn":10,"suggestions":"108"},{"ruleId":"95","severity":1,"message":"96","line":85,"column":25,"nodeType":"97","endLine":85,"endColumn":71},{"ruleId":"102","severity":1,"message":"103","line":101,"column":72,"nodeType":"104","messageId":"105","endLine":101,"endColumn":73},{"ruleId":"88","replacedBy":"109"},{"ruleId":"90","replacedBy":"110"},{"ruleId":"84","severity":1,"message":"111","line":12,"column":23,"nodeType":"86","messageId":"87","endLine":12,"endColumn":35},{"ruleId":"84","severity":1,"message":"112","line":15,"column":12,"nodeType":"86","messageId":"87","endLine":15,"endColumn":21},{"ruleId":"92","severity":1,"message":"93","line":29,"column":15,"nodeType":"94","endLine":31,"endColumn":6},{"ruleId":"92","severity":1,"message":"113","line"