alse);\n\n    const addLike = async () => {\n        if (userClicked === false) {\n            setNumOfLikes(numOfLikes + 1)\n            var postIdToSend = props.postId;\n            var postTitleToSend = props.postTitle;\n            var likesPlusOne = numOfLikes + 1;\n            await API.addLike(postIdToSend, likesPlusOne, postTitleToSend)\n                .then(setUserClicked(true));\n        } else if (userClicked === true) {\n            setNumOfLikes(numOfLikes - 1)\n            var postIdToSendTwo = props.postId;\n            var postTitleToSendTwo = props.postTitle;\n            var likesMinusOne = numOfLikes - 1;\n            await API.addLike(postIdToSendTwo, likesMinusOne, postTitleToSendTwo)\n                .then(setUserClicked(false));\n        }\n    }\n\n    if (userClicked === false) {\n        return (\n            <div className=\"likeContainer container-fixed\">\n                    <button className=\"heartBtn\" onClick={addLike}>\n                        <img className=\"heartImg\" src={photo}></img>\n                        <p className=\"heartCounter\" id={numOfLikes}>{numOfLikes}</p>\n                    </button>\n                </div>\n        )\n    } else if (userClicked === true) {\n        return (\n            <div className=\"likeContainer container-fixed\">\n                    <button className=\"heartBtn\" onClick={addLike}>\n                        <img className=\"heartImg\" src={photo}></img>\n                        <p className=\"heartCounter\">{numOfLikes}</p>\n                    </button>\n                </div>\n        )\n    }\n}","/Users/logan/Desktop/Active-Projects/peak-react/peak-fe/src/screens/Home.js",["58","59","60","61","62","63"],"/Users/logan/Desktop/Active-Projects/peak-react/peak-fe/src/screens/Signup.js",["64"],"import React, { useRef } from 'react';\nimport \"../stylesheets/signup.css\";\nimport { useHistory } from \"react-router-dom\";\n\nexport default function Signup () {\n\n    const history = useHistory();\n    const firstNameRef = useRef(null);\n    const lastNameRef = useRef(null);\n    const emailRef = useRef(null);\n    const passwordRef = useRef(null);\n    const ageRef = useRef(null);\n    const cityRef = useRef(null);\n    const zipRef = useRef(null);\n    const jobTitleRef = useRef(null);\n\n    const validateForm = e => {\n        e.preventDefault();\n        var signupObject = {\n            firstName = firstNameRef.current.value,\n            lastName = lastNameRef.current.value,\n            email = emailRef.current.value,\n            password = passwordRef.current.value,\n            age = ageRef.current.value,\n            city = cityRef.current.value,\n            zip = zipRef.current.value,\n            jobTitle = jobTitleRef.current.value\n        }\n        if(firstNameRef.current.value || lastNameRef.current.value || emailRef.current.value || passwordRef.current.value || ageRef.current.value || cityRef.current.value || zipRef.current.value || jobTitleRef.current.value === \"\"){\n            alert(\"Please fill out all required forms\")\n        }else{\n            signUpUser()\n        }\n    }\n\n    // const signUpUser = async (signupObject) => {\n    //     await\n\n    // }\n\n\n    return(\n        <div className=\"signupPage container-fixed\">\n            <div className=\"signupContainer\">\n                <form>\n                    <label>First</label>\n                    <input type=\"text\" ref={firstNameRef}></input>\n                    <label>Last</label>\n                    <input type=\"text\" ref={lastNameRef}></input>\n                    <label>Email</label>\n                    <input type=\"text\" ref={emailRef}></input>\n                    <label>Password</label>\n                    <input type=\"text\" ref={passwordRef}></input>\n                </form>\n                <form>\n                <label>Age</label>\n                <input type=\"text\" ref={ageRef}></input>\n                    <label>City</label>\n                    <input type=\"text\" ref={cityRef}></input>\n                    <label>Zip</label>\n                    <input type=\"text\" ref={zipRef}></input>\n                    <label>Title</label>\n                    <input type=\"text\" ref={jobTitleRef}></input>\n                </form>\n                <button onClick={validateForm} className=\"submit-btn\"><p>Sign Up</p></button>\n\n            </div>\n        </div>\n    )\n}","/Users/logan/Desktop/Active-Projects/peak-react/peak-fe/src/screens/InDepthPost.js",["65","66","67","68","69","70","71"],"/Users/logan/Desktop/Active-Projects/peak-react/peak-fe/src/screens/MyAccount.js",["72","73","74","75"],"/Users/logan/Desktop/Active-Projects/peak-react/peak-fe/src/components/blogBtnCont/index.js",["76","77","78","79","80"],"/Users/logan/Desktop/Active-Projects/peak-react/peak-fe/src/App.js",["81"],{"ruleId":"82","replacedBy":"83"},{"ruleId":"84","replacedBy":"85"},{"ruleId":"86","severity":1,"message":"87","line":17,"column":15,"nodeType":"88","endLine":21,"endColumn":6},{"ruleId":"86","severity":1,"message":"89","line":21,"column":8,"nodeType":"90","endLine":21,"endColumn":10,"suggestions":"91"},{"ruleId":"92","severity":1,"message":"93","line":23,"column":11,"nodeType":"94","messageId":"95","endLine":23,"endColumn":21},{"ruleId":"96","severity":1,"message":"97","line":65,"column":17,"nodeType":"98","endLine":65,"endColumn":37},{"ruleId":"92","severity":1,"message":"99","line":3,"column":8,"nodeType":"94","messageId":"95","endLine":3,"endColumn":16},{"ruleId":"96","severity":1,"message":"97","line":34,"column":25,"nodeType":"98","endLine":34,"endColumn":63},{"ruleId":"96","severity":1,"message":"97","line":43,"column":25,"nodeType":"98","endLine":43,"endColumn":63},{"ruleId":"92","severity":1,"message":"100","line":1,"column":40,"nodeType":"94","messageId":"95","endLine":1,"endColumn":46},{"ruleId":"92","severity":1,"message":"101","line":6,"column":8,"nodeType":"94","messageId":"95","endLine":6,"e